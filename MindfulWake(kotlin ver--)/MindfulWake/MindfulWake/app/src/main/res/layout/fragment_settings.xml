<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <TextView android:text="⚙️ Settings" android:textSize="22sp"
            android:textColor="@color/text_primary" android:textStyle="bold"
            android:paddingBottom="16dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:text="Alarm Sound" android:textColor="@color/text_secondary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <Spinner android:id="@+id/sound_spinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView android:text="Allow Snooze" android:textColor="@color/text_primary"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Switch android:id="@+id/snooze_toggle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView android:text="Wrong Answer Penalty (+1 Q)" android:textColor="@color/text_primary"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Switch android:id="@+id/penalty_toggle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView android:text="Question Timer (15s)" android:textColor="@color/text_primary"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Switch android:id="@+id/timer_toggle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView android:text="Smart Difficulty Adjust" android:textColor="@color/text_primary"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Switch android:id="@+id/auto_adjust_toggle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <TextView android:text="Gradual Volume Ramp" android:textColor="@color/text_primary"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Switch android:id="@+id/gradual_toggle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:text="Bedtime Target (HH:MM)" android:textColor="@color/text_secondary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/bedtime_input" android:inputType="time"
            android:textColor="@color/text_primary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView android:text="Bedtime Reminder (hours before)" android:textColor="@color/text_secondary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/bedtime_offset_input" android:inputType="number"
            android:textColor="@color/text_primary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView android:text="Morning Agenda" android:textColor="@color/text_secondary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/agenda_input" android:inputType="textMultiLine"
            android:minLines="3" android:textColor="@color/text_primary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <Button android:id="@+id/save_settings_btn" android:text="Save Settings"
            android:backgroundTint="@color/accent_purple" android:textColor="@color/white"
            android:layout_width="match_parent" android:layout_height="56dp"/>

    </LinearLayout>
</ScrollView>
