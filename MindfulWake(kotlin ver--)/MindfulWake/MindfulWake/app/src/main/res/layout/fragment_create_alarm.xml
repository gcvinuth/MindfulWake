<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView android:text="➕ Create Alarm" android:textSize="22sp"
            android:textColor="@color/text_primary" android:textStyle="bold"
            android:paddingBottom="20dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <!-- Time Picker -->
        <LinearLayout android:orientation="horizontal" android:gravity="center"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout android:orientation="vertical" android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content">
                <Button android:id="@+id/hour_up" android:text="▲"
                    android:layout_width="60dp" android:layout_height="40dp"/>
                <TextView android:id="@+id/hour_display" android:text="07"
                    android:textSize="40sp" android:textColor="@color/accent_purple"
                    android:textStyle="bold" android:gravity="center"
                    android:layout_width="80dp" android:layout_height="wrap_content"/>
                <Button android:id="@+id/hour_down" android:text="▼"
                    android:layout_width="60dp" android:layout_height="40dp"/>
            </LinearLayout>

            <TextView android:text=":" android:textSize="40sp" android:textColor="@color/text_primary"
                android:paddingHorizontal="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <LinearLayout android:orientation="vertical" android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content">
                <Button android:id="@+id/minute_up" android:text="▲"
                    android:layout_width="60dp" android:layout_height="40dp"/>
                <TextView android:id="@+id/minute_display" android:text="00"
                    android:textSize="40sp" android:textColor="@color/accent_purple"
                    android:textStyle="bold" android:gravity="center"
                    android:layout_width="80dp" android:layout_height="wrap_content"/>
                <Button android:id="@+id/minute_down" android:text="▼"
                    android:layout_width="60dp" android:layout_height="40dp"/>
            </LinearLayout>

            <LinearLayout android:orientation="vertical" android:gravity="center"
                android:layout_marginStart="16dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content">
                <Button android:id="@+id/btn_am" android:text="AM"
                    android:layout_width="60dp" android:layout_height="44dp"/>
                <Button android:id="@+id/btn_pm" android:text="PM"
                    android:layout_width="60dp" android:layout_height="44dp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Label -->
        <EditText android:id="@+id/alarm_label_input"
            android:hint="Label (e.g. Morning Workout)"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:inputType="text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Question Count -->
        <TextView android:text="Questions" android:textColor="@color/text_secondary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/question_count_display" android:text="3 questions"
            android:textColor="@color/accent_purple" android:textSize="18sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <SeekBar android:id="@+id/question_count_slider"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Difficulty -->
        <TextView android:text="Difficulty" android:textColor="@color/text_secondary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <Button android:id="@+id/btn_easy" android:text="Gentle"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btn_medium" android:text="Focused"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"/>
            <Button android:id="@+id/btn_hard" android:text="Intense"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Days -->
        <TextView android:text="Repeat" android:textColor="@color/text_secondary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <ToggleButton android:id="@+id/btn_sun" android:textOn="Su" android:textOff="Su"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp"/>
            <ToggleButton android:id="@+id/btn_mon" android:textOn="Mo" android:textOff="Mo"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp"/>
            <ToggleButton android:id="@+id/btn_tue" android:textOn="Tu" android:textOff="Tu"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp"/>
            <ToggleButton android:id="@+id/btn_wed" android:textOn="We" android:textOff="We"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp"/>
            <ToggleButton android:id="@+id/btn_thu" android:textOn="Th" android:textOff="Th"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp"/>
            <ToggleButton android:id="@+id/btn_fri" android:textOn="Fr" android:textOff="Fr"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp"/>
            <ToggleButton android:id="@+id/btn_sat" android:textOn="Sa" android:textOff="Sa"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp"/>
        </LinearLayout>

        <Button android:id="@+id/save_alarm_btn" android:text="Save Alarm"
            android:backgroundTint="@color/accent_purple"
            android:textColor="@color/white"
            android:layout_width="match_parent" android:layout_height="56dp"/>

    </LinearLayout>
</ScrollView>
