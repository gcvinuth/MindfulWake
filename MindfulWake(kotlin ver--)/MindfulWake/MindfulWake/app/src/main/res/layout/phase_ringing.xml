<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/bg_dark">

    <TextView android:text="⏰" android:textSize="80sp"
        android:gravity="center"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/ring_time"
        android:textSize="56sp" android:textColor="@color/accent_purple" android:textStyle="bold"
        android:gravity="center"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/ring_label"
        android:textSize="20sp" android:textColor="@color/text_primary"
        android:gravity="center" android:layout_marginTop="8dp" android:layout_marginBottom="40dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Button android:id="@+id/start_quiz_btn"
        android:text="🧠 Start Challenge"
        android:textSize="18sp"
        android:backgroundTint="@color/accent_purple"
        android:textColor="@color/white"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/snooze_btn"
        android:text="💤 Snooze (5 min)"
        android:backgroundTint="@color/accent_amber"
        android:textColor="@color/bg_dark"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="56dp"/>

</LinearLayout>
