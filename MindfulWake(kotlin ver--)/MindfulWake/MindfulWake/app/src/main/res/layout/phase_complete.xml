<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/bg_dark">

    <TextView android:text="🧠 Mind Awake!" android:textSize="32sp"
        android:textColor="@color/accent_purple" android:textStyle="bold"
        android:gravity="center" android:layout_marginBottom="24dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/complete_accuracy"
        android:textSize="20sp" android:textColor="@color/text_primary"
        android:gravity="center" android:layout_marginBottom="8dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/complete_time"
        android:textSize="16sp" android:textColor="@color/text_secondary"
        android:gravity="center" android:layout_marginBottom="32dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/morning_quote"
        android:textSize="15sp" android:textColor="@color/text_secondary"
        android:fontFamily="serif" android:textStyle="italic"
        android:gravity="center" android:layout_marginBottom="40dp"
        android:background="@drawable/card_bg" android:padding="16dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <Button android:id="@+id/done_btn"
        android:text="☀️ Start Your Day"
        android:backgroundTint="@color/accent_teal" android:textColor="@color/bg_dark"
        android:layout_width="match_parent" android:layout_height="64dp"/>

</LinearLayout>
